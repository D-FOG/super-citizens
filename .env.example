# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Supersite Citizens"

# Database
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DATABASE_URL=

# Auth
# Use a strong random value in production.
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Email
# Choose one provider and wire it in the API routes.
EMAIL_FROM="Supersite Citizens <hello@supersitecitizens.org>"
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Flutterwave
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=
FLW_REDIRECT_URL=http://localhost:3000/payments?status=success

# WhatsApp / Contact
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/
CONTACT_EMAIL=hello@supersitecitizens.org

# Admin / Access Control
ADMIN_EMAILS=
ORIENTATION_ACCESS_ROLE=Leader
