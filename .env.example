NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Database
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DATABASE_URL=

# Auth
# Use a strong random value in production.
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Email
# Choose one provider and wire it in the API routes.
EMAIL_FROM="Supersite Citizens <hello@supersitecitizens.org>"
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Flutterwave
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=
